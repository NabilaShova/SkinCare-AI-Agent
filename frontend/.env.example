# Backend API (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Shopify app URL (OAuth landing / dashboard)
NEXT_PUBLIC_SHOPIFY_APP_URL=http://localhost:3000

# Default Store ID for /chat and /embed/chat when ?store_id= is omitted
# Production (Render): set to connected store ID (e.g. 3)
NEXT_PUBLIC_DEMO_STORE_ID=1

# Fallback store name in dashboard sidebar
NEXT_PUBLIC_STORE_NAME=Glow Beauty Co.

# Local chat URLs:
#   http://localhost:3000/chat?store_id=1
#   http://localhost:3000/embed/chat?store_id=1
