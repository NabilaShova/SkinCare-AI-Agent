# Root environment file used by docker compose

# Required for production-quality AI responses
OPENAI_API_KEY=

# Model configuration (use gpt-4o in production for best chat accuracy)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.3

# Retrieval tuning
RAG_TOP_K=5
RAG_MIN_SCORE=0.12
PRODUCT_TOP_K=5
CHAT_HISTORY_LIMIT=12

# Promote helpful chat answers into knowledge base (RAG learning)
CHAT_AUTO_LEARN_ON_FEEDBACK=true

# Shopify OAuth (required for production Shopify onboarding)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_API_VERSION=2024-10
SHOPIFY_SCOPES=read_products,read_orders,read_content

# Public URLs (required for Shopify OAuth redirects)
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000

# Admin security
ADMIN_API_KEY=dev-admin-key-change-me
JWT_SECRET=dev-jwt-secret-change-me
SEED_DEMO_DATA=true
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_ADMIN_PER_MINUTE=120

# Default store for /chat and /embed/chat when store_id is omitted (1 = local demo)
DEMO_STORE_ID=1

# Production-only values (used with docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=support_agent
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_STORE_ID=1
NEXT_PUBLIC_STORE_NAME=Glow Beauty Co.
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
