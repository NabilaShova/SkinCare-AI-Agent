# Root environment file used by docker compose

# Required for high-quality AI responses (optional for local demo fallback mode)
OPENAI_API_KEY=

# Model configuration
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Shopify OAuth (required for production Shopify onboarding)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000

# Demo store id seeded on first startup
DEMO_STORE_ID=1
