# Copy to shopify.app.toml when scaffolding a Shopify CLI app.
# Production values below match the live Render deployment (2026-06-07).

name = "Skincare AI Support Agent"
client_id = "YOUR_SHOPIFY_API_KEY"
application_url = "https://skincare-frontend-z72h.onrender.com"
embedded = true

[access_scopes]
# read_customers optional — requires Protected Customer Data approval
scopes = "read_products,read_orders,read_content"

[auth]
redirect_urls = [
  "https://skincare-api-68pp.onrender.com/api/auth/callback"
]

[webhooks]
api_version = "2024-10"

# Future: theme app extension for one-click storefront chat widget
# Today: merchants paste integrations/shopify/glow-beauty-chat-widget.liquid into theme.liquid
# Merchant guide: docs/SHOPIFY_STORE_OWNER_GUIDE.md
