# Copy to shopify.app.toml after creating your Shopify Partner app.
# Update client_id and application_url before deploying.

name = "Skincare AI Support Agent"
client_id = "YOUR_SHOPIFY_API_KEY"
application_url = "https://app.yourdomain.com"
embedded = true

[access_scopes]
scopes = "read_products,read_orders,read_content"

[auth]
redirect_urls = [
  "https://api.yourdomain.com/api/auth/callback"
]

[webhooks]
api_version = "2024-10"
